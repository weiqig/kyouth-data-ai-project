# Database/state store
DATABASE_URL=postgresql+psycopg://user:password@postgres:5432/docs

# Queue broker only. Redis does not store business state.
REDIS_URL=redis://redis:6379/0

# Frontend/CORS
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Job recovery
JOB_MAX_ATTEMPTS=3
STALE_JOB_MINUTES=10

# AI layer
# Recommended local default: keep disabled or use mock until credentials are configured.
# Set AI_ENABLED=true to call the configured provider for parser types below.
AI_ENABLED=false
AI_PROVIDER=mock
AI_APPLY_TO_PARSER_TYPES=raw_text,markdown,pdf_text
AI_FALLBACK_TO_DETERMINISTIC=true
AI_TIMEOUT_SECONDS=60
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1

# Mock provider for offline demos
AI_MOCK_MODEL=mock-extractor

# Gemini provider. Recommended first real provider for this prototype.
# Get an API key from Google AI Studio, then set AI_PROVIDER=gemini and AI_ENABLED=true.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Anthropic / Claude provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# Ollama local provider. If you add an ollama service to compose, use http://ollama:11434.
# If running Ollama on your host outside Docker, use http://host.docker.internal:11434 on Docker Desktop.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=120

# Generic OpenAI-compatible gateway provider, useful for OpenRouter, vLLM, LM Studio, or internal gateways.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8001

{
  "key": "construction_purchase_order",
  "name": "Construction: Purchase Order",
  "industry": "construction",
  "description": "Procurement fields for construction materials, suppliers, and job-site purchasing.",
  "aliases": [
    "purchase order",
    "po",
    "material order"
  ],
  "fields": [
    {
      "key": "po_number",
      "label": "PO Number",
      "data_type": "string",
      "required": true,
      "aliases": [
        "purchase order number",
        "po #",
        "order number"
      ],
      "validation": {
        "min_length": 1
      }
    },
    {
      "key": "project_name",
      "label": "Project Name",
      "data_type": "string",
      "required": true,
      "aliases": [
        "project",
        "job name"
      ],
      "validation": {
        "min_length": 1
      }
    },
    {
      "key": "site_location",
      "label": "Site Location",
      "data_type": "string",
      "required": true,
      "aliases": [
        "site",
        "job site",
        "location"
      ],
      "validation": {
        "min_length": 1
      }
    },
    {
      "key": "supplier_name",
      "label": "Supplier Name",
      "data_type": "string",
      "required": true,
      "aliases": [
        "vendor",
        "supplier"
      ],
      "validation": {
        "min_length": 1
      }
    },
    {
      "key": "requested_by",
      "label": "Requested By",
      "data_type": "string",

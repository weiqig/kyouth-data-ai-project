      "data_type": "currency",
      "required": true,
      "aliases": [
        "total",
        "amount",
        "order total"
      ],
      "validation": {
        "min": 0,
        "currencies": [
          "RM",
          "MYR",
          "USD",
          "SGD"
        ],
        "require_currency_symbol": false
      }
    },
    {
      "key": "cost_code",
      "label": "Cost Code",
      "data_type": "string",
      "required": false,
      "aliases": [
        "budget code",
        "cost center"
      ],
      "validation": {
        "min_length": 1
      }
    }
  ]
}

      "data_type": "date",
      "required": true,
      "aliases": [
        "date"
      ],
      "validation": {
        "formats": [
          "YYYY-MM-DD",
          "DD/MM/YYYY"
        ]
      }
    },
    {
      "key": "delivery_date",
      "label": "Delivery Date",
      "data_type": "date",
      "required": false,
      "aliases": [
        "required by",
        "delivery"
      ],
      "validation": {
        "formats": [
          "YYYY-MM-DD",
          "DD/MM/YYYY"
        ]
      }
